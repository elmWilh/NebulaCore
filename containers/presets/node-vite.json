{
  "name": "node-vite",
  "title": "Node Vite Frontend",
  "description": "Frontend development preset for Vite with host bind and dependency install flow",
  "ui": {
    "protocol_label": "Vite Frontend",
    "protocol_hint": "Frontend dev server with public host bind.",
    "protocol_preferred": true,
    "website_wizard": {
      "enabled": true,
      "type": "node-vite",
      "label": "Vite Frontend",
      "preferred": true,
      "internal_port": 5173,
      "default_public_port": 5173
    }
  },
  "config": {
    "image": "node:20-alpine",
    "ram": 1024,
    "swap": 2048,
    "disk": 20,
    "cpu": 1024,
    "cpu_limit": 1.0,
    "cpuset": "",
    "cpu_quota": "",
    "cpu_period": "",
    "pids_limit": 256,
    "shm": 128,
    "ports": "5173:5173",
    "project_protocol": "node-vite",
    "install_command": "npm install",
    "command": "npm run dev -- --host 0.0.0.0 --port 5173",
    "env": "NODE_ENV=development\nPORT=5173",
    "volumes": "",
    "domain_name": "",
    "launch_url": "",
    "workspace_mount": "/app",
    "explorer_root": "/app",
    "console_cwd": "/app",
    "profile_name": "node-vite",
    "restart": true
  },
  "permissions": {
    "user": { "allow_explorer": true, "allow_root_explorer": false, "allow_console": true, "allow_shell": false, "allow_settings": false, "allow_edit_files": false, "allow_edit_startup": false, "allow_edit_ports": false },
    "developer": { "allow_explorer": true, "allow_root_explorer": false, "allow_console": true, "allow_shell": true, "allow_settings": true, "allow_edit_files": true, "allow_edit_startup": true, "allow_edit_ports": true }
  }
}
