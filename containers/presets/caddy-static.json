{
  "name": "caddy-static",
  "title": "Caddy Static Site",
  "description": "Static site hosting preset using Caddy with simple public routing defaults",
  "ui": {
    "protocol_label": "Static Web Content",
    "protocol_hint": "Best for caddy/nginx static images that already ship their own entrypoint.",
    "protocol_preferred": true,
    "website_wizard": {
      "enabled": true,
      "type": "static-web",
      "label": "Static Site",
      "preferred": true,
      "internal_port": 80,
      "default_public_port": 8080
    }
  },
  "config": {
    "image": "caddy:2-alpine",
    "ram": 512,
    "swap": 1024,
    "disk": 10,
    "cpu": 512,
    "cpu_limit": 0.7,
    "cpuset": "",
    "cpu_quota": "",
    "cpu_period": "",
    "pids_limit": 128,
    "shm": 64,
    "ports": "8080:80",
    "project_protocol": "static-web",
    "install_command": "",
    "command": "",
    "env": "TZ=UTC",
    "volumes": "",
    "domain_name": "",
    "launch_url": "",
    "workspace_mount": "/usr/share/caddy",
    "explorer_root": "/usr/share/caddy",
    "console_cwd": "/usr/share/caddy",
    "profile_name": "caddy-static",
    "restart": true
  },
  "permissions": {
    "user": { "allow_explorer": true, "allow_root_explorer": false, "allow_console": false, "allow_shell": false, "allow_settings": false, "allow_edit_files": false, "allow_edit_startup": false, "allow_edit_ports": false },
    "developer": { "allow_explorer": true, "allow_root_explorer": false, "allow_console": true, "allow_shell": true, "allow_settings": true, "allow_edit_files": true, "allow_edit_startup": true, "allow_edit_ports": true }
  }
}
