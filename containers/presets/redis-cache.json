{
  "name": "redis-cache",
  "title": "Redis Cache",
  "description": "Lightweight Redis cache preset for app backends and queue workers",
  "config": {
    "image": "redis:7-alpine",
    "ram": 768,
    "swap": 1024,
    "disk": 8,
    "cpu": 512,
    "cpu_limit": 0.6,
    "cpuset": "",
    "cpu_quota": "",
    "cpu_period": "",
    "pids_limit": 128,
    "shm": 64,
    "ports": "6379:6379",
    "project_protocol": "generic",
    "install_command": "",
    "command": "",
    "env": "TZ=UTC",
    "volumes": "",
    "domain_name": "",
    "launch_url": "",
    "workspace_mount": "/data",
    "explorer_root": "/data",
    "console_cwd": "/data",
    "profile_name": "redis-cache",
    "restart": true
  },
  "permissions": {
    "user": { "allow_explorer": false, "allow_root_explorer": false, "allow_console": false, "allow_shell": false, "allow_settings": false, "allow_edit_files": false, "allow_edit_startup": false, "allow_edit_ports": false },
    "developer": { "allow_explorer": true, "allow_root_explorer": false, "allow_console": true, "allow_shell": true, "allow_settings": true, "allow_edit_files": true, "allow_edit_startup": true, "allow_edit_ports": true }
  }
}
